@replace-first src/pages/employees/EmployeeDetailsPage.tsx
@find
      <HrEntityDialog
        entity="employees"
        initialRecord={employee}
        mode="edit"
        onOpenChange={setIsEditOpen}
        onSubmit={handleEmployeeUpdate}
        open={isEditOpen}
      />
@endfind
@with
      <EmployeeSectionEditDialog
        employee={employee}
        employeeId={employeeId}
        onOpenChange={(open) => {
          setIsEditOpen(open);

          if (!open) {
            setEditingSection(null);
          }
        }}
        onSaved={handleEmployeeSaved}
        open={isEditOpen}
        section={editingSection}
      />
@endwith
@end
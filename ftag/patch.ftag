@replace-first src/pages/employees/EmployeeCreatePage.tsx
@find
                  isCompleted ? 'bg-blue-500' : 'bg-slate-200',
@endfind
@with
                  isCompleted ? 'bg-[var(--accent)]' : 'bg-[var(--color-border)]',
@endwith
@end

@replace-first src/pages/employees/EmployeeCreatePage.tsx
@find
                  isCompleted
                    ? 'border-blue-600 bg-blue-600 text-white shadow-lg shadow-blue-600/25'
                    : isActive
                      ? 'border-blue-600 bg-white text-blue-600 shadow-sm ring-4 ring-blue-50'
                      : 'border-slate-200 bg-slate-50 text-slate-400',
@endfind
@with
                  isCompleted
                    ? 'border-[var(--accent)] bg-[var(--accent)] text-white shadow-lg'
                    : isActive
                      ? 'border-[var(--accent)] bg-[var(--color-surface)] text-[var(--accent)] shadow-sm ring-4 ring-[var(--accent-ring)]'
                      : 'border-[var(--color-border)] bg-[var(--color-surface-muted)] text-[var(--color-text-muted)]',
@endwith
@end

@replace-first src/pages/employees/EmployeeCreatePage.tsx
@find
                  isCompleted || isActive ? 'text-blue-600' : 'text-slate-500',
@endfind
@with
                  isCompleted || isActive ? 'app-accent-text' : 'app-muted',
@endwith
@end

@replace-first src/pages/DashboardPage.tsx
@find
                <span className="rounded-full bg-emerald-100 px-3 py-1 text-xs font-black text-emerald-700">
@endfind
@with
                <span className="app-accent-soft rounded-full px-3 py-1 text-xs font-black">
@endwith
@end

@replace-first src/features/hr-table/HrEntityTable.tsx
@find
                      className="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-400"
@endfind
@with
                      className="app-button-secondary app-accent-text inline-flex h-9 w-9 items-center justify-center rounded-xl border p-0 shadow-sm transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent-border)]"
@endwith
@end

@replace-first src/features/hr-table/HrEntityTable.tsx
@find
                      className="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-rose-100 bg-white text-rose-500 shadow-sm transition hover:border-rose-200 hover:bg-rose-50 hover:text-rose-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-rose-400"
@endfind
@with
                      className="app-danger-soft inline-flex h-9 w-9 items-center justify-center rounded-xl border p-0 shadow-sm transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-rose-400"
@endwith
@end

@replace-first src/shared/ui/Button.tsx
@find

            <div className="mb-4 flex flex-wrap justify-end gap-3">
              <Button
                type="button"
                variant="secondary"
                leftIcon={<FiEdit2 className="h-4 w-4" />}
                onClick={() => openSectionEditor("personal")}
              >
                Личные данные
              </Button>
              <Button
                type="button"
                variant="secondary"
                leftIcon={<FiEdit2 className="h-4 w-4" />}
                onClick={() => openSectionEditor("address")}
              >
                Адресные данные
              </Button>
            </div>
@endwith
@end


@find

function optionalNumberString(): z.ZodString {
  return z
    .string()
    .trim()
    .refine((value) => value === '' || Number.isFinite(Number(value)), requiredMessage)
    .refine((value) => value === '' || Number(value) >= 0, nonNegativeMessage)
}
@endfind
@with
@endwith
@end